# AgroCure backend secrets — copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must NEVER be committed.

# OpenAI API key for the "Sage" AI plant-care companion.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Which chat model Sage uses (optional — defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini
